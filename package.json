{
  "name": "lilla",
  "version": "0.1.0",
  "description": "Lightweight reactive library for native Web Components.",
  "type": "module",
  "module": "./dist/lilla.es.js",
  "exports": {
    ".": {
      "import": "./dist/lilla.es.js",
      "default": "./dist/lilla.es.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "vite --open /examples/",
    "build": "vite build",
    "prepublishOnly": "npm run test:run && npm run build",
    "preversion": "npm run test:run"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "reactive",
    "shadow-dom",
    "lightweight",
    "micro-framework",
    "no-build",
    "template-literals",
    "progressive-enhancement",
    "vanilla-js",
    "esm",
    "tiny-framework",
    "js-framework",
    "zero-build"
  ],
  "author": "Ethical Gradient",
  "license": "MIT",
  "devDependencies": {
    "happy-dom": "^12.10.3",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
